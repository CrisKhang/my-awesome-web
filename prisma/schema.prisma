generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Review {
  id        String   @id @default(cuid())
  name      String
  phone     String
  rating    Int
  content   String
  role      String?
  project   String?
  image     String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
